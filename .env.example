# ─── SERVER ────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ─── MongoDB ───────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fixradar

# ─── Firebase Admin SDK ────────────────────────────────────────
# Valores del archivo firebase-adminsdk.json
FIREBASE_PROJECT_ID=fixradar-77067
FIREBASE_PRIVATE_KEY_ID=b1956cc9cb1aba174c4c3dc8a42a019cecc3822e
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@fixradar-77067.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=109093921396939942314
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=*

# ─── RATE LIMITING ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── JWT (email/password auth) ─────────────────────────────────
JWT_SECRET=cambia-esto-por-una-clave-segura-de-al-menos-32-chars
JWT_EXPIRES_IN=30d

# ─── RSA Keys (generadas automáticamente al arrancar si no existen)
# Copia los valores que imprime el servidor en el primer arranque:
# RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
# RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── Email (para envío de códigos de verificación) ─────────────
# Gmail: habilita "Contraseñas de aplicación" en tu cuenta Google
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu@gmail.com
EMAIL_PASS=tu-contrasena-de-aplicacion
EMAIL_FROM="FixRadar <noreply@fixradar.com>"
